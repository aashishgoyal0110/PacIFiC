.PHONY: all libgrains grains clean

all: libgrains grains



LIBGRAINS_SRCDIR := $(GRAINS_SRCDIR_ABS)/Grains
LIBGRAINS_LIBDIR := $(GRAINS_LIBDIR)
LIBGRAINS_OBJDIR := $(GRAINS_OBJDIR)
LIBGRAINS_SHAREDIR := $(GRAINS_SHAREDIR)

MAIN_SRCDIR := $(GRAINS_SRCDIR_ABS)/Main
MAIN_BINDIR := $(GRAINS_BINDIR)

LIBGRAINS_MAKE = $(MAKE) -C $(LIBGRAINS_SRCDIR) \
  LIBGRAINS_SRCDIR=$(LIBGRAINS_SRCDIR) \
  LIBGRAINS_LIBDIR=$(LIBGRAINS_LIBDIR) \
  LIBGRAINS_OBJDIR=$(LIBGRAINS_OBJDIR) \
  LIBGRAINS_SHAREDIR=$(LIBGRAINS_SHAREDIR)

MAIN_MAKE = $(MAKE) -C $(MAIN_SRCDIR) \
  MAIN_SRCDIR=$(MAIN_SRCDIR) \
  MAIN_BINDIR=$(MAIN_BINDIR) \
  LIBGRAINS_LIBDIR=$(LIBGRAINS_LIBDIR) \
  LIBGRAINS_SRCDIR=$(LIBGRAINS_SRCDIR) 

libgrains:
	$(LIBGRAINS_MAKE) all

grains: libgrains
	$(MAIN_MAKE) all

clean: 
	$(LIBGRAINS_MAKE) clean
	$(MAIN_MAKE) clean
