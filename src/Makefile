
#
# Grains3D
#

GRAINS_SRCDIR_ABS = $(PACIFIC_SRCDIR_ABS)/Grains3D
GRAINS_BUILDDIR_ABS = $(PACIFIC_BUILDDIR_ABS)/Grains
GRAINS_LIBDIR := $(GRAINS_BUILDDIR_ABS)/lib
GRAINS_OBJDIR := $(GRAINS_BUILDDIR_ABS)/obj
GRAINS_BINDIR := $(GRAINS_BUILDDIR_ABS)/bin
GRAINS_SHAREDIR := $(GRAINS_BUILDDIR_ABS)/share/Grains

GRAINS_MAKE = $(MAKE) -C $(GRAINS_SRCDIR_ABS) \
	GRAINS_BUILDDIR_ABS=$(GRAINS_BUILDDIR_ABS) \
	GRAINS_SRCDIR_ABS=$(GRAINS_SRCDIR_ABS) \
	GRAINS_LIBDIR=$(GRAINS_LIBDIR) \
	GRAINS_OBJDIR=$(GRAINS_OBJDIR) \
	GRAINS_BINDIR=$(GRAINS_BINDIR) \
	GRAINS_SHAREDIR=$(GRAINS_SHAREDIR)

grains: 
	$(GRAINS_MAKE) all

#
# Cartesian/MAC
#

MAC_SRCDIR_ABS = $(PACIFIC_SRCDIR_ABS)/Cartesian/MAC
MAC_BUILDDIR_ABS = $(PACIFIC_BUILDDIR_ABS)/MAC
MAC_OBJDIR = $(MAC_BUILDDIR_ABS)/obj
MAC_LIBDIR = $(MAC_BUILDDIR_ABS)/lib
MAC_MAKE = $(MAKE) -C $(MAC_SRCDIR_ABS) \
	MAC_BUILDDIR_ABS=$(MAC_BUILDDIR_ABS) \
	MAC_OBJDIR=$(MAC_OBJDIR) \
	MAC_LIBDIR=$(MAC_LIBDIR) \
	MAC_SRCDIR_ABS=$(MAC_SRCDIR_ABS) 

mac: 
	$(MAC_MAKE) all
#
# Cartesian/FLUID
#

FLUID_SRCDIR_ABS = $(PACIFIC_SRCDIR_ABS)/Cartesian/FLUID
FLUID_BUILDDIR_ABS = $(PACIFIC_BUILDDIR_ABS)/FLUID
FLUID_OBJDIR = $(FLUID_BUILDDIR_ABS)/obj
FLUID_LIBDIR = $(FLUID_BUILDDIR_ABS)/lib
FLUID_MAKE = $(MAKE) -C $(FLUID_SRCDIR_ABS) \
	FLUID_BUILDDIR_ABS=$(FLUID_BUILDDIR_ABS) \
	FLUID_OBJDIR=$(FLUID_OBJDIR) \
	FLUID_LIBDIR=$(FLUID_LIBDIR) \
	FLUID_SRCDIR_ABS=$(FLUID_SRCDIR_ABS) \
	MAC_SRCDIR_ABS=$(MAC_SRCDIR_ABS) \
	MAC_LIBDIR=$(MAC_LIBDIR) \
	GRAINS_SRCDIR_ABS=$(GRAINS_SRCDIR_ABS) \
	GRAINS_LIBDIR=$(GRAINS_LIBDIR)

fluid: 
	$(FLUID_MAKE) all

#
#
#

clean:
	$(GRAINS_MAKE) clean
	$(MAC_MAKE) clean
	$(FLUID_MAKE) clean

.PHONY: all

all: grains mac fluid
